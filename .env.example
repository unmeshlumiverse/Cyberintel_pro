# CyberIntel Pro — Environment Config
# Auto-loaded by server.js — no dotenv needed

PGHOST=localhost
PGPORT=5432
PGDATABASE=cyberintel_pro
PGUSER=postgres
PGPASSWORD=
ADMIN_PASSWORD=

const JWT_SECRET = JWT_SECRET;


PORT=3000

# ── Gemini API Keys ─────────────────────────────────────────────────
# NEW FORMAT: Google now issues "AQ." auth keys (sent via x-goog-api-key header)
# OLD FORMAT: "AIzaSy" standard keys (being phased out by Sept 2026)
# Both formats work with this server. Get keys: https://aistudio.google.com/app/apikey
GEMINI_KEY_1=# Add more keys to avoid rate limits:
GEMINI_KEY_2=
GEMINI_KEY_3=
# ── MXToolbox ───────────────────────────────────────────────────────
MXTOOLBOX_KEY=

# ── Intelligence APIs ───────────────────────────────────────────────
VIRUSTOTAL_KEY=
GREYNOISE_KEY=
URLSCAN_KEY=
ABUSEIPDB_KEY=

# ── Real decision-maker email data (has a free tier, still open to signup) ──
HUNTER_API_KEY=
# Optional generic web search fallback (Google CSE is closed to new signups)
SERPER_API_KEY=